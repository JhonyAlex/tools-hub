// ============================================================
// PRISMA SCHEMA - Tools Hub
// Each tool's models are grouped with a comment header.
// Model names MUST be prefixed with the tool name: [ToolName][ModelName]
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ CORE: Tool metadata (optional persistence) ============
model ToolUsageLog {
  id        String   @id @default(cuid())
  toolSlug  String
  action    String
  createdAt DateTime @default(now())

  @@index([toolSlug])
}

// ============ MAINTENANCE REPORT TOOL ============
model MaintenanceReport {
  id          String   @id @default(cuid())
  reportDate  DateTime // The date this report covers
  csvFileName String
  metrics     Json     // ReportMetrics object
  notes       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([reportDate])
}

// ============ MAINTENANCE REPORT SEM-MES TOOL ============
model MaintenanceReportSemMes {
  id             String   @id @default(cuid())
  periodType     String   // "semanal" | "mensual" | "custom"
  dateRangeStart DateTime
  dateRangeEnd   DateTime
  csvFileName    String
  metrics        Json     // SemMesReportMetrics object
  notes          String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([dateRangeStart])
  @@index([periodType])
}
