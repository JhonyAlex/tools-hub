// ============================================================
// PRISMA SCHEMA - Tools Hub
// Each tool's models are grouped with a comment header.
// Model names MUST be prefixed with the tool name: [ToolName][ModelName]
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ CORE: Tool metadata (optional persistence) ============
model ToolUsageLog {
  id        String   @id @default(cuid())
  toolSlug  String
  action    String
  createdAt DateTime @default(now())

  @@index([toolSlug])
}
