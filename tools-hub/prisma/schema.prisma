// ============================================================
// PRISMA SCHEMA - Tools Hub
// Each tool's models are grouped with a comment header.
// Model names MUST be prefixed with the tool name: [ToolName][ModelName]
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ CORE: Tool metadata (optional persistence) ============
model ToolUsageLog {
  id        String   @id @default(cuid())
  toolSlug  String
  action    String
  createdAt DateTime @default(now())

  @@index([toolSlug])
}

// ============ MAINTENANCE REPORT TOOL ============
model MaintenanceReport {
  id          String   @id @default(cuid())
  reportDate  DateTime // The date this report covers
  csvFileName String
  metrics     Json     // ReportMetrics object
  notes       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([reportDate])
}

// ============ MAINTENANCE REPORT SEM-MES TOOL ============
model MaintenanceReportSemMes {
  id             String   @id @default(cuid())
  periodType     String   // "semanal" | "mensual" | "custom"
  dateRangeStart DateTime
  dateRangeEnd   DateTime
  csvFileName    String
  metrics        Json     // SemMesReportMetrics object
  notes          String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([dateRangeStart])
  @@index([periodType])
}

// ============ AURIS LM TOOL ============
model AurisLMSpace {
  id          String              @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  documents   AurisLMDocument[]
  messages    AurisLMChatMessage[]
}

model AurisLMDocument {
  id            String        @id @default(cuid())
  spaceId       String
  space         AurisLMSpace  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  originalName  String
  storedPath    String        // relative to /app/uploads
  mimeType      String
  fileSize      Int
  extractedText String        @db.Text
  status        String        @default("processing") // "processing" | "ready" | "error"
  errorMessage  String?
  createdAt     DateTime      @default(now())
  chunks        AurisLMChunk[]

  @@index([spaceId])
  @@index([status])
}

model AurisLMChunk {
  id          String          @id @default(cuid())
  documentId  String
  document    AurisLMDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  spaceId     String
  content     String          @db.Text
  chunkIndex  Int
  tokenCount  Int             @default(0)
  createdAt   DateTime        @default(now())

  @@index([spaceId])
  @@index([documentId])
}

model AurisLMChatMessage {
  id             String       @id @default(cuid())
  spaceId        String
  space          AurisLMSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  role           String       // "user" | "assistant"
  content        String       @db.Text
  webSearchUsed  Boolean      @default(false)
  sources        Json?        // [{docName: string, snippet: string}]
  createdAt      DateTime     @default(now())

  @@index([spaceId])
  @@index([createdAt])
}

// ============ DOC CHAT TOOL ============
model DocChatSession {
  id            String           @id @default(cuid())
  fileName      String
  mimeType      String
  extractedText String           @db.Text
  systemPrompt  String?          @db.Text
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  messages      DocChatMessage[]
}

model DocChatMessage {
  id        String         @id @default(cuid())
  sessionId String
  session   DocChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String         // "user" | "assistant" | "system"
  content   String         @db.Text
  createdAt DateTime       @default(now())

  @@index([sessionId])
}
