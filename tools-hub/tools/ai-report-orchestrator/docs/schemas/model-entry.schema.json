{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tools-hub.local/schemas/ai-report-orchestrator/model-entry.schema.json",
  "title": "ModelEntry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "nombre",
    "providerId",
    "providerNombre",
    "prompt",
    "activo",
    "version",
    "metadatos"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9._:-]{3,128}$"
    },
    "nombre": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "providerId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-zA-Z0-9_-]{3,64}$"
    },
    "providerNombre": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "prompt": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64000
    },
    "activo": {
      "type": "boolean"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "metadatos": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        },
        "maxTokens": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200000
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "maxItems": 50
        }
      }
    },
    "promptHistory": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["version", "prompt", "updatedAt", "updatedBy"],
        "properties": {
          "version": { "type": "integer", "minimum": 1 },
          "prompt": { "type": "string", "minLength": 1, "maxLength": 64000 },
          "updatedAt": { "type": "string", "format": "date-time" },
          "updatedBy": { "type": "string", "minLength": 1, "maxLength": 120 },
          "changeNote": { "type": "string", "maxLength": 500 }
        }
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
